<%- include("partials/header", { title: title }) %>

<div class="page">
    <div class="container">
        <h1 class="page__title"><%= title %></h1>

        <form method="GET" action="/items" class="form form--inline">
            <input 
                type="text" 
                name="search" 
                placeholder="Search items..."
                value="<%= search || '' %>"
            >

            <select name="rarity">
                <option value="">All Rarity</option>
                <option value="Common" <%= rarity === "Common" ? "selected" : "" %>>Common</option>
                <option value="Uncommon" <%= rarity === "Uncommon" ? "selected" : "" %>>Uncommon</option>
                <option value="Rare" <%= rarity === "Rare" ? "selected" : "" %>>Rare</option>
                <option value="Epic" <%= rarity === "Epic" ? "selected" : "" %>>Epic</option>
                <option value="Legendary" <%= rarity === "Legendary" ? "selected" : "" %>>Legendary</option>
            </select>

            <button type="submit">Filter</button>
        </form>

        <div class="grid grid--items">
            <% if (items.length > 0) { %>
                <ul class="grid__list">
                    <% items.forEach(item => { %>
                        <li class="grid__item">
                            <a href="/items/<%= item.id %>" class="card card--item">

                                <div class="card__content">
                                    <h3 class="card__title"><%= item.name %></h3>

                                    <% if (item.description) { %>
                                        <p class="card__text"><%= item.description %></p>
                                    <% } %>

                                    <% if (item.price != undefined) { %>
                                        <p class="card__meta"><strong>Price:</strong> <%= item.price %> 🪙</p>
                                    <% } %>

                                    <% if (item.rarity) { %>
                                        <p class="card__meta"><strong>Rarity:</strong> <%= item.rarity %></p>
                                    <% } %>

                                    <% if (item.categories && item.categories.length > 0) { %>
                                        <p class="card__meta">
                                            <strong>Categories:</strong>
                                            <% item.categories.forEach((cat, i) => { %>
                                                <%= cat %><%= i < item.categories.length - 1 ? ", " : "" %>
                                            <% }) %>
                                        </p>
                                    <% } %>
                                </div>

                            </a>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p>No items found.</p>
            <% } %>
        </div>
    </div>
</div>
<%- include("partials/footer") %>