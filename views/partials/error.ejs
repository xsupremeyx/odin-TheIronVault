<% if (errors && errors.length > 0) { %>
    <div class="alert alert--error" role="alert" aria-live="polite">
        <div class="alert__title">Please fix the following</div>
        <ul>
            <% errors.forEach(error => { %>
                <li><%= error.msg %></li>
            <% }) %>
        </ul>
    </div>
<% } %>