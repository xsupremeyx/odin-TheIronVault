<%- include("partials/header", { title: title }) %>

<div class="page page--detail">
    <div class="container">
        <section class="detail-shell">

            <div class="category__icon">
                <img src="<%= category.image_url %>" alt="<%= category.name %>">
            </div>

            <h1 class="page__title"><%= category.name %></h1>

            <% if (category.description) { %>
                <p><%= category.description %></p>
            <% } %>

            <hr>
            
            <a href="/categories/<%= category.id %>/edit" class="action-link">
                Edit Category
            </a>

            <%- include("partials/error", { errors: errors || [] }) %>

            <form action="/categories/<%= category.id %>/delete" method="POST" class="form form--danger">
                <div class="form__group">
                    <label class="form__label">Admin Password</label>
                    <input class="form__input" type="password" name="admin_password" required>
                </div>
                <div class="form__actions">
                <button type="submit" class="btn btn--danger" onclick="return confirm('Delete this category?')">
                    Delete Category
                </button>
                </div>

            </form>

        </section>    

        <h2 class="page__subtitle page__subtitle--items">Items in this category</h2>

        <% if (items.length > 0) { %>
            <ul class="item-list grid grid--items">
                <% items.forEach(item => { %>
                    <li class="item-card card card--item">
                        <a href="/items/<%= item.id %>">
                            <div class="card__content">
                                <h3 class="card__title"><%= item.name %></h3>

                                <% if (item.description) { %>
                                    <p class="card__text"><%= item.description %></p>
                                <% } %>

                                <% if (item.price != undefined) { %>
                                    <p class="card__meta"><strong>Price:</strong> <%= item.price %> 🪙</p>
                                <% } %>

                                <% if (item.rarity) { %>
                                    <p class="card__meta card__meta--rarity">
                                        <strong>Rarity:</strong>
                                        <span class="rarity-badge rarity-badge--<%= item.rarity.toLowerCase() %>"><%= item.rarity %></span>
                                    </p>
                                <% } %>
                            </div>
                        </a>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No items in this category yet.</p>
        <% } %>

        <a href="/categories" class="back-link">Back to Categories</a>
    </div>
</div>

<%- include("partials/footer") %>